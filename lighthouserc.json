{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:18005"
      ],
      "startServerCommand": "vite preview --config config/prod.config.ts --port 18005",
      "startServerWaitTimeout": 60000,
      "numberOfRuns": 3,
      "chromePath": "/usr/bin/chromium"
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "first-contentful-paint": [
          "warn",
          {
            "maxNumericValue": 2000
          }
        ],
        "interactive": [
          "error",
          {
            "maxNumericValue": 5000
          }
        ]
      }
    }
  }
}